# Copy to .env and fill in secrets before running.
# Never commit .env to version control.

POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=replace_with_strong_password

KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=replace_with_strong_password

# Full public URL Keycloak is reachable at, e.g. https://sso.example.com
KC_HOSTNAME=https://sso.example.com

# Bare hostname only (no scheme/path) — used in Traefik Host() router rule
KC_HOSTNAME_BARE=sso.example.com

# Email for Let's Encrypt ACME registration
TRAEFIK_ACME_EMAIL=admin@example.com
